# ===== Public Ports =====
FRONTEND_PUBLIC_PORT=3100
BACKEND_PUBLIC_PORT=3101
DB_PUBLIC_PORT=5433
REDIS_PUBLIC_PORT=6380
PGADMIN_PORT=5050

# ===== PostgreSQL =====
DB_USERNAME=raguser
DB_PASSWORD=changeme
DB_NAME=ragdb
DB_SYNCHRONIZE=true

# ===== JWT =====
JWT_SECRET=change-this-super-secret
JWT_EXPIRATION=1h

# ===== Ingestion =====
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ===== OpenRouter =====
OPENROUTER_API_KEY=
OPENROUTER_MODELS=meta-llama/llama-3.2-3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-coder:free
OPENROUTER_REFERER=https://example.com
OPENROUTER_TITLE=RAG Backend

# ===== Frontend Build =====
NEXT_PUBLIC_API_URL=http://localhost:3101
NEXT_PUBLIC_DEMO_MODE=false

# ===== pgAdmin =====
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-this-password
