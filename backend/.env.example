# ============================================
# RAG Backend - Environment Variables
# ============================================

# Database (PostgreSQL + pgvector)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=raguser
DB_PASSWORD=changeme
DB_NAME=ragdb
DB_SYNCHRONIZE=true
DB_SSL=false
DB_IP_FAMILY=4

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_URL=



# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRATION=1h

# Ingestion
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
INGESTION_JOB_TIMEOUT_MS=600000
INGESTION_INSERT_BATCH_SIZE=100
EXCEL_PROCESS_ALL_SHEETS=false

# App
PORT=3000
NODE_ENV=development

# OpenRouter (Requerido para chat RAG)
# ─────────────────────────────────────
# OPENROUTER_API_KEY: Tu llave de API en https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Modelos a usar (free por defecto, pero pueden tener rate limits)
# Para producción, usa modelos de pago como:
# - openai/gpt-4o-mini (recomendado, mejor precio-rendimiento)
# - openai/gpt-3.5-turbo
# - anthropic/claude-3.5-sonnet
# El backend usa fallback automático: intenta free → luego pago
OPENROUTER_MODELS=meta-llama/llama-3.2-3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-coder:free

# Modelo "inteligente" opcional para consultas complejas (ejemplo: gpt-oss-120b)
# Se usa primero cuando RAG detecta baja confianza o cuando RAG_FORCE_SMART_MODEL=true
OPENROUTER_SMART_MODEL=

# RAG tuning
RAG_TOP_K=8
RAG_MIN_SIMILARITY=0.15
RAG_FORCE_SMART_MODEL=false

# Headers opcionales para OpenRouter
OPENROUTER_REFERER=https://github.com/CamiloTriana75/RAG-Backend
OPENROUTER_TITLE=NestJS RAG Backend
